# Docker Compose project name — keeps volume/network names compatible
# with the original aspirant-online deployment so existing data carries over
COMPOSE_PROJECT_NAME=aspirant-online

# Authentication
JWT_SECRET=change-me

# Database (PostgreSQL)
DB_HOST=postgres
DB_USER=aspirant_user
DB_PASSWORD=change-me
DB_NAME=aspirant_db

# AWS (used by server for S3 asset storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
S3_BUCKET_NAME=
FINANCE_URL=http://finance:8000
